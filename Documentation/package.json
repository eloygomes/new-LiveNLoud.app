{
  "name": "sustenido-documentation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "npm run validate && astro build",
    "check": "astro check",
    "validate": "astro check && node scripts/validate-content.mjs && node scripts/validate-restricted.mjs && node scripts/check-links.mjs",
    "test": "node --test tests/*.test.mjs",
    "preview": "astro preview --host 0.0.0.0"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@tailwindcss/vite": "^4.1.11",
    "astro": "^7.1.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.11"
  }
}
