---
interface Props { status: 'delivered' | 'beta' | 'planned' | 'legacy' }
const { status } = Astro.props;
const labels = { delivered: 'Entregue', beta: 'Beta', planned: 'Planejado', legacy: 'Legado' };
const styles = { delivered: 'bg-emerald-100 text-emerald-900', beta: 'bg-amber-200 text-amber-950', planned: 'bg-blue-100 text-blue-900', legacy: 'bg-zinc-200 text-zinc-800' };
---
<span class:list={['inline-flex rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wide', styles[status]]}>{labels[status]}</span>
