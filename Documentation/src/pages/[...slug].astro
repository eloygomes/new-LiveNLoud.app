---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import Notice from '../components/Notice.astro';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/');
const entry = await getEntry('docs', slug);
if (!entry) return new Response('Página não encontrada.', { status: 404 });
const { Content } = await render(entry);
const restricted = entry.data.visibility === 'restricted';
---
<DocsLayout title={entry.data.title} description={entry.data.description} featureStatus={entry.data.featureStatus} restricted={restricted}>
  {entry.data.featureStatus === 'beta' && (
    <Notice type="beta" title="Recurso Beta">
      O comportamento pode mudar e depende de serviços, navegadores, arquivos ou dispositivos externos. Relate falhas pelo canal de suporte do #Sustenido.
    </Notice>
  )}
  {entry.data.featureStatus === 'planned' && <Notice title="Recurso planejado">Esta capacidade ainda não está disponível como recurso concluído.</Notice>}
  {restricted && <Notice type="restricted" title="Conteúdo restrito">Não copie este procedimento para canais públicos e nunca inclua credenciais, tokens ou dados pessoais.</Notice>}
  <Content />
</DocsLayout>
