---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import Notice from '../../components/Notice.astro';
const entry = await getEntry('docs', 'operacao/verificacao-de-disponibilidade');
if (!entry) throw new Error('Conteúdo operacional não encontrado');
const { Content } = await render(entry);
---
<DocsLayout title={entry.data.title} description={entry.data.description} featureStatus={entry.data.featureStatus} restricted>
  <Notice type="restricted" title="Conteúdo restrito">Este exemplo não contém hosts internos, credenciais, dados pessoais nem segredos.</Notice>
  <Content />
</DocsLayout>
