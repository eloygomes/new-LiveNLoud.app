---
import { getEntry, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import Notice from '../../components/Notice.astro';
const entry = await getEntry('docs', 'usuario/primeiros-passos');
if (!entry) throw new Error('Conteúdo usuario/primeiros-passos não encontrado');
const { Content } = await render(entry);
---
<DocsLayout title={entry.data.title} description={entry.data.description} featureStatus={entry.data.featureStatus}>
  <Notice title="Antes de começar">O cadastro depende de aprovação por e-mail. Você só poderá entrar depois que a conta for aprovada.</Notice>
  <Content />
</DocsLayout>
