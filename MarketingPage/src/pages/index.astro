---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header';
import Faq from '../components/Faq';
import HeroScene from '../components/HeroScene';
import { faqs, navItems, site } from '../config/site';

const ctaLabel = site.cta.labels[site.cta.mode];
const ctaHref = site.cta.url || '#acesso';
const year = new Date().getFullYear();

const productPreviews = [
  { src: '/screenshots/dashboard-opcoes.png', label: 'Visão geral', title: 'Progresso, filtros e setlists' },
  { src: '/screenshots/edicao-musica.png', label: 'Workspace da música', title: 'Partes, arquivos, vídeos e notas' },
  { src: '/screenshots/nova-musica.png', label: 'Nova música', title: 'Tudo organizado desde o primeiro registro' },
];

const labTools = [
  { className: 'drum', src: '/screenshots/drum-machine.png', label: 'Drum machine', title: 'Transforme uma ideia em groove.', copy: 'Crie padrões, escolha timbres, ajuste cada voz e experimente arranjos sem interromper o fluxo.' },
  { className: 'tuner', src: '/screenshots/afinador.png', label: 'Afinador', title: 'Afinação pronta para começar.', copy: 'Detecção automática, diferentes instrumentos e afinações reunidos na sua área de preparação.' },
  { className: 'metronome', src: '/screenshots/metronomo.png', label: 'Metrônomo', title: 'Tempo e prática sob controle.', copy: 'Ajuste BPM, use tap tempo, cronômetro e timer para estudar com objetivo.' },
  { className: 'chords', src: '/screenshots/dicionario-acordes.png', label: 'Dicionário de acordes', title: 'Encontre a sonoridade certa.', copy: 'Explore raízes, extensões, baixos e diferentes voicings para tirar a ideia do papel.' },
];

const rehearsalEvents = [
  { day: '18', kind: 'Ensaio geral', meta: '19:30 · Estúdio A', people: '4 integrantes' },
  { day: '22', kind: 'Reunião de repertório', meta: '20:00 · Online', people: '4 integrantes' },
  { day: '26', kind: 'Passagem de som', meta: '16:00 · Casa Aurora', people: '3 integrantes' },
  { day: '31', kind: 'Show', meta: '22:00 · Casa Aurora', people: 'Banda completa' },
];

const audiences = [
  {
    n: '01', title: 'Músicos', eyebrow: 'Estudo e repertório',
    copy: 'Para quem precisa saber o que tocar, onde está cada referência e o que ainda falta preparar.',
    items: ['Catálogo por instrumento', 'Progresso de cada música', 'Ferramentas de prática'],
  },
  {
    n: '02', title: 'Bandas', eyebrow: 'Ensaio e palco',
    copy: 'Para grupos que querem alinhar agenda, setlists e materiais antes de todos entrarem na sala.',
    items: ['Agenda compartilhada', 'Convites entre integrantes', 'Modo LIVE e footswitch'],
  },
  {
    n: '03', title: 'Compositores e produtores', eyebrow: 'Ideias e arranjos',
    copy: 'Para desenvolver uma ideia sem perder referências, versões, grooves ou decisões de arranjo.',
    items: ['Drum machine', 'Dicionário de acordes', 'Vídeos, arquivos e notas'],
  },
  {
    n: '04', title: 'Professores e estudantes', eyebrow: 'Rotina e evolução',
    copy: 'Para transformar uma lista solta de músicas em um caminho de estudo mais claro e consistente.',
    items: ['Metas visíveis', 'Histórico de execução', 'Materiais no mesmo lugar'],
  },
];
---
<BaseLayout title="Sustenido — Da primeira ideia ao palco" description="A plataforma do músico para catalogar repertório, preparar ensaios, criar ideias e tocar ao vivo com tudo no lugar certo.">
  <div id="top"></div>
  <Header client:load nav={navItems} ctaLabel={ctaLabel} ctaUrl={site.cta.url} appUrl={site.appUrl} />
  <main>
    <section class="hero section-shell" aria-labelledby="hero-title">
      <div class="hero-copy" data-reveal>
        <p class="eyebrow"><span></span> O workspace do músico</p>
        <h1 id="hero-title">Da primeira ideia ao palco, <em>tudo no mesmo compasso.</em></h1>
        <p class="lead">Do primeiro link salvo à última música do show: catalogue seu repertório, prepare cada parte, desenvolva novas ideias, organize ensaios e leve tudo para o palco em um só lugar.</p>
        <div class="actions">
          <a class="button" href={ctaHref} data-event="cta_primary_click">{ctaLabel}<span aria-hidden="true">↗</span></a>
          <a class="text-link" href="#produto" data-event="cta_secondary_click">Ver como funciona <span aria-hidden="true">↓</span></a>
        </div>
        <p class="trust">Repertório <b>•</b> Preparação <b>•</b> Criação <b>•</b> Ao vivo</p>
      </div>
      <div class="hero-visual" data-reveal>
        <HeroScene client:visible />
      </div>
    </section>

    <section class="manifesto section-shell" aria-labelledby="manifesto-title">
      <p class="section-index">01 — O problema</p>
      <div class="manifesto-grid">
        <div class="manifesto-intro" data-reveal>
          <h2 id="manifesto-title">Menos abas.<br/><em>Mais música.</em></h2>
          <p>A rotina musical se espalha com facilidade: um link no grupo, uma cifra no navegador, um arquivo no computador e a data do ensaio em outra conversa. O Sustenido reúne cada etapa sem tirar a música do centro.</p>
        </div>
        <div class="transform-list" data-reveal>
          <article>
            <div><small>NA ROTINA</small><strong>Referências espalhadas</strong><p>Links, vídeos, cifras e arquivos ficam perdidos entre favoritos, mensagens e pastas.</p></div>
            <b aria-hidden="true">→</b>
            <div><small>COM O SUSTENIDO</small><strong>Cada parte junto da música</strong><p>Guarde materiais de guitarra, baixo, teclas, bateria e voz no mesmo registro.</p></div>
          </article>
          <article>
            <div><small>NA ROTINA</small><strong>Repertório sem contexto</strong><p>Você lembra da música, mas não do tom, afinação, setlist ou última vez que tocou.</p></div>
            <b aria-hidden="true">→</b>
            <div><small>COM O SUSTENIDO</small><strong>Um catálogo que trabalha por você</strong><p>Encontre dados, tags, setlists, arquivos, notas e histórico sem reconstruir o contexto.</p></div>
          </article>
          <article>
            <div><small>NA ROTINA</small><strong>Preparação no improviso</strong><p>O ensaio chega sem uma visão clara do que está pronto e do que precisa de atenção.</p></div>
            <b aria-hidden="true">→</b>
            <div><small>COM O SUSTENIDO</small><strong>Progresso visível por instrumento</strong><p>Acompanhe a evolução de cada parte e filtre exatamente o que precisa ser praticado.</p></div>
          </article>
          <article>
            <div><small>NA ROTINA</small><strong>Ferramentas desconectadas</strong><p>Afinador, metrônomo, calendário e ideias vivem longe do repertório que você está preparando.</p></div>
            <b aria-hidden="true">→</b>
            <div><small>COM O SUSTENIDO</small><strong>Um fluxo contínuo até o palco</strong><p>Prepare, crie, combine encontros e entre no modo LIVE sem trocar de ambiente.</p></div>
          </article>
        </div>
      </div>
    </section>

    <section id="produto" class="product section-shell dark-section" aria-labelledby="product-title">
      <div class="product-heading" data-reveal>
        <div>
          <p class="section-index">02 — Produto</p>
          <h2 id="product-title">A plataforma<br/>do músico. <em>Do repertório ao palco.</em></h2>
        </div>
        <p>Catalogue suas músicas com todos os materiais de que precisa. Prepare-se com afinador e metrônomo, transforme ideias em grooves na drum machine, organize os encontros da banda e conte com o modo LIVE quando chegar a hora de tocar.</p>
      </div>

      <div class="product-showcase" data-reveal>
        <figure class="app-preview product-main-preview">
          <div class="preview-bar"><i></i><i></i><i></i><span>Repertório</span><b>sustenido.eloygomes.com</b></div>
          <div class="shot-viewport"><img src="/screenshots/repertorio.png" alt="Tela real do repertório no Sustenido, com músicas, artistas, tags e instrumentos" loading="lazy" /></div>
          <figcaption><span>Seu repertório inteiro em perspectiva</span><small>Busque, filtre e veja o estado de cada música.</small></figcaption>
        </figure>
        <div class="product-preview-grid">
          {productPreviews.map((preview) =>
            <figure class="app-preview compact">
              <div class="preview-bar"><i></i><i></i><i></i><span>{preview.label}</span></div>
              <div class="shot-viewport"><img src={preview.src} alt={`${preview.title} no Sustenido`} loading="lazy" /></div>
              <figcaption><span>{preview.title}</span></figcaption>
            </figure>
          )}
        </div>
      </div>

      <div class="feature-line" data-reveal>
        <span><b>Catalogue</b> músicas, partes e setlists</span>
        <span><b>Prepare</b> afinação, tempo e materiais</span>
        <span><b>Crie</b> grooves e explore acordes</span>
        <span><b>Toque</b> com o suporte do modo LIVE</span>
      </div>
    </section>

    <section class="flow section-shell" aria-labelledby="flow-title">
      <p class="section-index">03 — Fluxo</p>
      <div class="section-heading split" data-reveal><h2 id="flow-title">Da música ao ensaio,<br/><em>sem perder o contexto.</em></h2><p>O caminho inteiro cabe em três movimentos.</p></div>
      <div class="steps">
        <article data-reveal><span>01</span><div class="step-icon capture"><i></i><i></i><i></i></div><h3>Capture</h3><p>Comece do zero ou adicione uma música por link. Registre artista, tom, afinação e tudo que acompanha cada instrumento.</p></article>
        <article data-reveal><span>02</span><div class="step-icon organize"><i></i><i></i><i></i></div><h3>Prepare</h3><p>Organize setlists, acompanhe o progresso e use as ferramentas certas para chegar ao ensaio sabendo o que merece atenção.</p></article>
        <article data-reveal><span>03</span><div class="step-icon play"><i></i></div><h3>Crie e toque</h3><p>Teste grooves e acordes, alinhe a agenda da banda e leve o repertório em sequência para o palco com o modo LIVE.</p></article>
      </div>
    </section>

    <section id="recursos" class="lab section-shell" aria-labelledby="lab-title">
      <div class="section-heading" data-reveal>
        <p class="section-index">04 — Laboratório</p>
        <h2 id="lab-title">Ferramentas para <em>praticar, experimentar e criar.</em></h2>
        <p>O laboratório fica ao lado do seu repertório. Afine, estude no tempo certo, descubra novas formas de tocar um acorde e construa a base rítmica da próxima ideia.</p>
      </div>
      <div class="lab-grid lab-real-grid">
        {labTools.map((tool) =>
          <figure class={`real-tool-card ${tool.className}`} data-reveal>
            <div class="tool-shot"><img src={tool.src} alt={`Tela real de ${tool.label} no Sustenido`} loading="lazy" /></div>
            <figcaption><small>{tool.label}</small><h3>{tool.title}</h3><p>{tool.copy}</p></figcaption>
          </figure>
        )}
      </div>
    </section>

    <section class="rehearsal section-shell" aria-labelledby="rehearsal-title">
      <div class="rehearsal-copy" data-reveal>
        <p class="section-index">05 — Ensaio</p>
        <h2 id="rehearsal-title">A agenda da banda, <em>com todos no mesmo compasso.</em></h2>
        <p>Convide os integrantes e organize em um só calendário os ensaios, reuniões, passagens de som e shows. Cada pessoa vê as próximas datas, os participantes e o contexto do encontro antes de confirmar.</p>
        <div class="member-row" aria-label="Quatro integrantes da banda">
          <span>EG</span><span>GU</span><span>MA</span><span>LU</span><b>4 integrantes conectados</b>
        </div>
      </div>
      <div class="rehearsal-visual" data-reveal>
        <figure class="calendar-screenshot">
          <img src="/screenshots/calendario.png" alt="Tela real do calendário do Sustenido" loading="lazy" />
          <figcaption>Tela real do calendário</figcaption>
        </figure>
        <div class="band-agenda">
          <div class="agenda-heading"><div><small>JULHO 2026</small><h3>Agenda da banda</h3></div><span>4 pessoas</span></div>
          <div class="agenda-events">
            {rehearsalEvents.map((event) =>
              <article><b>{event.day}</b><div><strong>{event.kind}</strong><small>{event.meta}</small></div><span>{event.people}</span></article>
            )}
          </div>
        </div>
      </div>
    </section>

    <section class="live section-shell dark-section" aria-labelledby="live-title">
      <div class="live-copy" data-reveal>
        <p class="section-index">06 — Ao vivo</p>
        <h2 id="live-title">O palco na tela.<br/><em>O controle aos seus pés.</em></h2>
        <p>No modo LIVE, o Sustenido simplifica a interface para a apresentação: você acompanha a ordem do setlist, identifica a música e a parte atual e avança pelo show sem procurar arquivos ou voltar ao dashboard.</p>
        <p>Conecte um footswitch compatível por MIDI ou Bluetooth, mapeie os comandos necessários e troque de música com os pés. Suas mãos continuam no instrumento — exatamente onde devem estar.</p>
        <ul class="live-points">
          <li>Setlist em sequência e leitura rápida</li>
          <li>Navegação anterior e próxima sem tocar na tela</li>
          <li>Mapeamento de pedais no próprio Sustenido</li>
        </ul>
        <a class="text-link light" href="#faq">Ver compatibilidade <span>↘</span></a>
      </div>
      <div class="live-visual" data-reveal>
        <div class="signal signal-a"></div><div class="signal signal-b"></div><div class="signal signal-c"></div>
        <div class="live-screen">
          <div class="live-screen-top"><span>AGORA</span><small>03 / 12</small></div>
          <h3>Come Together</h3><p>The Beatles · Baixo</p>
          <div class="live-progress"><i></i></div><div class="live-actions"><b>← Anterior</b><b>Próxima →</b></div>
        </div>
        <figure class="footswitch-preview">
          <img src="/screenshots/footswitch.png" alt="Tela real de conexão e configuração de footswitch Bluetooth e MIDI no Sustenido" loading="lazy" />
          <figcaption><i></i><span>Footswitch conectado</span><b>Bluetooth &amp; MIDI</b></figcaption>
        </figure>
        <div class="connection"><i></i> Pronto para o LIVE</div>
      </div>
      <p class="compat-note">A disponibilidade depende do dispositivo, navegador e conexão usados. Confirme a configuração antes da apresentação.</p>
    </section>

    <section id="para-quem" class="audiences section-shell" aria-labelledby="audience-title">
      <div class="audience-heading" data-reveal>
        <div><p class="section-index">07 — Para quem</p><h2 id="audience-title">Uma plataforma.<br/><em>Cada rotina encontra seu fluxo.</em></h2></div>
        <p>Do estudo individual à agenda da banda, da primeira batida ao último bis: o Sustenido acompanha quem faz a música acontecer.</p>
      </div>
      <div class="audience-grid">
        {audiences.map((audience) =>
          <article data-reveal>
            <div class="audience-card-top"><span>{audience.n}</span><small>{audience.eyebrow}</small></div>
            <h3>{audience.title}</h3>
            <p>{audience.copy}</p>
            <ul>{audience.items.map((item) => <li>{item}</li>)}</ul>
          </article>
        )}
      </div>
      <div class="audience-close" data-reveal><span>Uma única fonte de verdade</span><p>O repertório conecta a preparação, a criação, o ensaio e o palco — mesmo quando a sua forma de fazer música muda.</p></div>
    </section>

    <section id="acesso" class="pricing section-shell" aria-labelledby="pricing-title">
      <div class="pricing-card" data-reveal>
        <div><p class="eyebrow light"><span></span> Acesso antecipado</p><h2 id="pricing-title">Tudo o que sua música precisa para <em>seguir em frente.</em></h2><p>Repertório, workspace por música, laboratório de ferramentas, ensaios e suporte ao LIVE em uma única plataforma.</p></div>
        <div class="pricing-action"><span>PLANOS EM BREVE</span><a class="button" href={site.cta.url || '#faq'}>{ctaLabel}<b>↗</b></a><small>Nenhuma cobrança nesta etapa.</small></div>
      </div>
    </section>

    <section id="faq" class="faq section-shell" aria-labelledby="faq-title">
      <div class="faq-heading" data-reveal><p class="section-index">08 — FAQ</p><h2 id="faq-title">Antes do<br/><em>primeiro acorde.</em></h2><p>Respostas diretas sobre o workspace e o acesso inicial.</p></div>
      <Faq client:visible items={faqs} />
    </section>

    <section class="final-cta section-shell" aria-labelledby="final-title">
      <div class="final-ring" aria-hidden="true"></div><p class="eyebrow"><span></span> Sustenido</p><h2 id="final-title" data-reveal>Sua rotina musical pode<br/><em>tocar no mesmo ritmo.</em></h2><a class="button" href={ctaHref}>{ctaLabel}<span>↗</span></a>
    </section>
  </main>
  <footer class="footer section-shell"><a class="brand" href="#top"><span>#</span> SUSTENIDO</a><p>Da primeira ideia ao palco.</p><nav aria-label="Rodapé"><a href="#produto">Produto</a>{site.appUrl && <a href={site.appUrl}>Entrar</a>}{site.contactEmail && <a href={`mailto:${site.contactEmail}`}>Contato</a>}</nav><small>© {year} Sustenido. Todos os direitos reservados.</small></footer>
</BaseLayout>
