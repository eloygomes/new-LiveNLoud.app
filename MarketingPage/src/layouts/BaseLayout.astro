---
import '../styles/global.css';
import { site } from '../config/site';

interface Props { title: string; description: string }
const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Sustenido',
  applicationCategory: 'MusicApplication',
  operatingSystem: 'Web',
  description,
  url: site.url,
};
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#efefec" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.svg', site.url)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <slot />
    <script is:inline>
      document.documentElement.classList.add('js');
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealItems = document.querySelectorAll('[data-reveal]');
      if (!reduced) {
        const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
        }), { threshold: .12 });
        revealItems.forEach((el) => observer.observe(el));
      } else {
        revealItems.forEach((el) => el.classList.add('is-visible'));
      }

      const parallaxItems = document.querySelectorAll('[data-parallax]');
      let ticking = false;
      const updateMotion = () => {
        document.querySelector('[data-header]')?.classList.toggle('scrolled', scrollY > 18);
        const compactMotion = matchMedia('(max-width: 700px), (pointer: coarse)').matches;
        if (!reduced && !compactMotion) parallaxItems.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.bottom < -200 || rect.top > innerHeight + 200) return;
          const speed = Number(el.getAttribute('data-parallax-speed') || '.04');
          const distance = rect.top + rect.height / 2 - innerHeight / 2;
          el.style.setProperty('--parallax-shift', `${distance * speed}px`);
        });
        ticking = false;
      };
      const requestMotion = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(updateMotion);
      };
      addEventListener('scroll', requestMotion, { passive: true });
      addEventListener('resize', requestMotion, { passive: true });
      updateMotion();

      document.querySelectorAll('[data-carousel-controls]').forEach((controls) => {
        const track = document.getElementById(controls.getAttribute('data-carousel-controls'));
        if (!track) return;
        const slides = [...track.querySelectorAll('[data-carousel-slide]')];
        const status = controls.querySelector('[data-carousel-status]');
        const previous = controls.querySelector('[data-carousel-prev]');
        const next = controls.querySelector('[data-carousel-next]');
        let active = 0;
        let carouselFrame = 0;

        const updateCarousel = () => {
          const trackLeft = track.getBoundingClientRect().left;
          active = slides.reduce((closest, slide, index) => {
            const currentDistance = Math.abs(slide.getBoundingClientRect().left - trackLeft);
            const closestDistance = Math.abs(slides[closest].getBoundingClientRect().left - trackLeft);
            return currentDistance < closestDistance ? index : closest;
          }, 0);
          slides.forEach((slide, index) => slide.toggleAttribute('data-carousel-active', index === active));
          if (status) status.textContent = `${active + 1} / ${slides.length}`;
          if (previous) previous.disabled = active === 0;
          if (next) next.disabled = active === slides.length - 1;
          carouselFrame = 0;
        };

        const goTo = (index) => {
          const target = slides[Math.max(0, Math.min(slides.length - 1, index))];
          if (!target) return;
          const left = target.getBoundingClientRect().left - track.getBoundingClientRect().left + track.scrollLeft;
          track.scrollTo({ left, behavior: reduced ? 'auto' : 'smooth' });
        };

        previous?.addEventListener('click', () => goTo(active - 1));
        next?.addEventListener('click', () => goTo(active + 1));
        track.addEventListener('scroll', () => {
          if (carouselFrame) return;
          carouselFrame = requestAnimationFrame(updateCarousel);
        }, { passive: true });
        addEventListener('resize', updateCarousel, { passive: true });
        updateCarousel();
      });
    </script>
  </body>
</html>
