---
interface Props {
  target: string;
  label: string;
}

const { target, label } = Astro.props;
---
<div class="mobile-carousel-controls" data-carousel-controls={target} aria-label={`Controles de ${label}`}>
  <div>
    <strong>{label}</strong>
    <span data-carousel-status aria-live="polite">1 / 1</span>
  </div>
  <div class="mobile-carousel-actions">
    <button type="button" data-carousel-prev aria-label={`Ver item anterior de ${label}`}>←</button>
    <button type="button" data-carousel-next aria-label={`Ver próximo item de ${label}`}>→</button>
  </div>
</div>
