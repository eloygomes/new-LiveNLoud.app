# Copy to Server/liveNloud/.env on the VPS and replace every placeholder.
# This file is read by Server/liveNloud/docker-compose.yml through env_file: ./.env.

MONGO_ROOT_USER=replace-with-mongo-root-user
MONGO_ROOT_PASS=replace-with-mongo-root-password
APP_DATABASE_NAME=liveNloud_
MONGO_URI=mongodb://replace-with-mongo-root-user:replace-with-mongo-root-password@db:27017/admin

ACCESS_SECRET=replace-with-a-long-random-access-secret
REFRESH_SECRET=replace-with-a-long-random-refresh-secret
BCRYPT_ROUNDS=12

FRONTEND_BASE_URL=https://live.eloygomes.com
API_PUBLIC_BASE_URL=https://api.live.eloygomes.com
CORS_ALLOWED_ORIGINS=https://live.eloygomes.com,https://www.live.eloygomes.com,http://localhost:5173
API_RATE_LIMIT_WINDOW_MS=900000
API_GENERAL_RATE_LIMIT_MAX=1000
API_AUTH_LOGIN_RATE_LIMIT_MAX=30
API_AUTH_SENSITIVE_RATE_LIMIT_MAX=20
API_EXPENSIVE_RATE_LIMIT_MAX=120
API_UPLOAD_RATE_LIMIT_MAX=60

PYTHON_API_URL=http://python_scraper:8000

SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_TLS_SERVERNAME=replace-with-smtp-tls-servername
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=Live N Loud <replace-with-smtp-user>
APPROVAL_ADMIN_EMAILS=replace-with-admin-email

YOUTUBE_CLIENT_ID=replace-with-youtube-client-id
YOUTUBE_CLIENT_SECRET=replace-with-youtube-client-secret
YOUTUBE_STATE_SECRET=replace-with-youtube-state-secret
YOUTUBE_REDIRECT_URI=https://api.live.eloygomes.com/api/youtube/auth/callback
YOUTUBE_FRONT_CALLBACK_PATH=/yt/done
YOUTUBE_FRONTEND_AFTER_AUTH=https://www.live.eloygomes.com
YOUTUBE_FRONT_OK_URL=https://live.eloygomes.com
YOUTUBE_FRONT_FAIL_URL=https://live.eloygomes.com
