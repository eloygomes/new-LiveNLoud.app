# Local Node API settings for running `npm start` inside Server/sustenido/node.
# Copy this file to .env and replace placeholder values.

PORT=3000
NODE_ENV=development

# Local Docker Mongo:
MONGO_URI=mongodb://replace-with-user:replace-with-password@localhost:27017/admin
APP_DATABASE_NAME=sustenido

ACCESS_SECRET=replace-with-a-long-random-access-secret
REFRESH_SECRET=replace-with-a-long-random-refresh-secret
BCRYPT_ROUNDS=12

PYTHON_API_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
API_PUBLIC_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_RATE_LIMIT_WINDOW_MS=900000
API_GENERAL_RATE_LIMIT_MAX=5000
API_AUTH_LOGIN_RATE_LIMIT_MAX=120
API_AUTH_SENSITIVE_RATE_LIMIT_MAX=120
API_EXPENSIVE_RATE_LIMIT_MAX=500
API_UPLOAD_RATE_LIMIT_MAX=200

# Optional email approval flow settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS_SERVERNAME=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APPROVAL_ADMIN_EMAILS=
