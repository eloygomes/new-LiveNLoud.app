PORT=5175
NODE_ENV=production

# Banco proprio do painel Admin. No Docker Compose, use o admin-db interno.
ADMIN_DB_NAME=adminPanel
ADMIN_MONGO_ROOT_USER=admin_root
ADMIN_MONGO_ROOT_PASSWORD=replace-with-a-strong-admin-mongo-password
ADMIN_ACCESS_SECRET=replace-with-a-long-random-admin-access-secret
ADMIN_REFRESH_SECRET=replace-with-a-long-random-admin-refresh-secret

# Primeiro usuario do painel Admin. Troque a senha depois de entrar.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-temporary-password

# Banco alvo administrado pelo painel. Use a porta publicada do Mongo do Sustenido
# no host do VPS, sem colocar o Admin na rede Docker do Sustenido.
SUSTENIDO_MONGO_URI=mongodb://user:password@host.docker.internal:27018/admin
TARGET_DB_NAME=sustenido

ADMIN_PUBLIC_ORIGIN=https://admin.sustenido.eloygomes.com
FRONTEND_BASE_URL=https://sustenido.eloygomes.com
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

SMTP_HOST=
SMTP_PORT=587
SMTP_TLS_SERVERNAME=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
